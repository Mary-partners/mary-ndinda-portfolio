# Password for the Admin / Moderation dashboard (/admin).
# Set this before running in any shared environment.
ADMIN_PASSWORD=change-me-please

# Public site URL, used for SEO/Open Graph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email notifications (Resend) ---
# When set, new collaboration leads and new post-it submissions are emailed.
# Get a key at https://resend.com (free tier available).
RESEND_API_KEY=

# Where notification emails are sent. Defaults to the site contact address.
NOTIFY_EMAIL=mary@managementcapitallab.com

# The "from" address. Must be a Resend-verified sender. Until you verify your
# domain in Resend, the shared sandbox sender below delivers to your own inbox.
EMAIL_FROM=The Management Capital Lab <onboarding@resend.dev>

# --- Notion database (optional, recommended for permanent storage) ---
# When all three are set, contributions and leads are stored in Notion instead
# of the local JSON file. Create an internal integration at
# https://www.notion.so/profile/integrations, share both databases with it,
# then paste the token and database IDs here.
NOTION_TOKEN=
NOTION_CONTRIBUTIONS_DB=
NOTION_LEADS_DB=
